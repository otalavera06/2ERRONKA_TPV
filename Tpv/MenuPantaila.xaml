<Window x:Class="Tpv.Menu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:Tpv"
        mc:Ignorable="d" 
        Title="Musinelli TPV" Height="450" Width="800"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource BrandSoft}"
        UseLayoutRounding="True">
    <Window.Resources>
        <Style TargetType="{x:Type Button}" x:Key="MenuBotoia" BasedOn="{StaticResource LuxuryCardButton}">
            <Setter Property="Foreground" Value="{StaticResource BrandIvory}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="20"/>
            <Setter Property="Background" Value="{StaticResource BrandBlack}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="20"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type Button}" x:Key="MenukoBotoiakIragarri" BasedOn="{StaticResource MenuBotoia}">
            <Setter Property="Background" Value="{StaticResource BrandBlack}"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Background="{StaticResource BrandBlack}" Grid.Row="0" MouseLeftButtonDown="Titulua_EzkerrekoBotoiaKlik">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Click="Txat_Klik">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle Width="35" Height="35" Fill="{StaticResource BrandGold}" Margin="3">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/txat.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Click="Eguraldia_Klik" Margin="10,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Path Data="M17.52,17.52c0-3.32,2.69-6.01,6.01-6.01c0.61,0,1.2,0.09,1.75,0.26c1.13-2.13,3.35-3.58,5.92-3.58c3.08,0,5.69,2.1,6.41,4.95 c0.54-0.14,1.1-0.22,1.69-0.22c3.7,0,6.7,3,6.7,6.7c0,3.7-3,6.7-6.7,6.7H17.52V17.52z" 
                                       Fill="{StaticResource BrandGold}" 
                                       Stretch="Uniform" 
                                       Width="35" Height="35" 
                                       Margin="3"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.ToolTip>
                        <Border Background="{StaticResource BrandSurface}" CornerRadius="5" Padding="3">
                            <TextBlock Text="Eguraldia (XML)"
                                       Foreground="{StaticResource BrandBlack}"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Button.ToolTip>
                </Button>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Click="Profil_Klik" HorizontalAlignment="Left">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle x:Name="Ikonoa" Width="35" Height="35" Fill="{StaticResource BrandIvory}" Margin="3">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/usuario.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2C2415"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#2C2415"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.ToolTip>
                        <Border Background="{StaticResource BrandSurface}" CornerRadius="5" Padding="3">
                            <TextBlock Text="Saioa Itxi"
                       Foreground="{StaticResource BrandBlack}"
                       FontSize="14"
                       FontWeight="SemiBold"/>
                        </Border>
                    </Button.ToolTip>
                </Button>
                <Button Content="_" Width="45" Height="45" Margin="4" Click="Minimizatu_Klik" Background="Transparent" Foreground="{StaticResource BrandIvory}" FontSize="22" FontWeight="Bold"/>
                <Button Content="X" Width="45" Height="45" Margin="4" Click="Itxi_Klik" Background="Transparent" Foreground="{StaticResource BrandIvory}" FontSize="22" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
            
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource MenuBotoia}"
                    Click="Eskaerak_Klik">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Width="60" Height="60" Fill="{StaticResource BrandGold}" Margin="0,0,0,10">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/eskaera.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Eskaerak" Foreground="{StaticResource BrandIvory}" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="1"
                    Style="{StaticResource MenuBotoia}"
                    Click="Fakturak_Klik">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Width="60" Height="60" Fill="{StaticResource BrandGold}" Margin="0,0,0,10">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/Faktura.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Fakturak" Foreground="{StaticResource BrandIvory}" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="2"
                    Style="{StaticResource MenuBotoia}"
                    Click="Erreserbak_Klik">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Width="60" Height="60" Fill="{StaticResource BrandGold}" Margin="0,0,0,10">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/Mesa.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Erreserbak" Foreground="{StaticResource BrandIvory}" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
