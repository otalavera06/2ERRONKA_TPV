<Window x:Class="Tpv.EguraldiaLeihoa"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eguraldia (AEMET)" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrandSoft}">
    <Window.Resources>
        <Style x:Key="WeatherCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.1" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="lblHerria" Text="Kargatzen..." FontSize="36" FontWeight="Bold" Foreground="{StaticResource BrandBlack}"/>
            <TextBlock x:Name="lblProbintzia" Text="..." FontSize="18" Foreground="{StaticResource BrandMuted}"/>
        </StackPanel>
        
        <!-- Today Main Card -->
        <Border Grid.Row="1" Style="{StaticResource WeatherCard}" Background="{StaticResource BrandBlack}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Gaur" Foreground="{StaticResource BrandGold}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="lblGaurData" Text="-" Foreground="{StaticResource BrandIvory}" FontSize="20"/>
                    <TextBlock x:Name="lblGaurEgoera" Text="-" Foreground="{StaticResource BrandIvory}" FontSize="28" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="lblGaurTenperatura" Text="--°C" Foreground="{StaticResource BrandGold}" FontSize="48" FontWeight="Bold"/>
                    <TextBlock x:Name="lblGaurMinMax" Text="Min: --°C | Max: --°C" Foreground="{StaticResource BrandIvory}" FontSize="16" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Forecast List -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Hurrengo egunak" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrandBlack}" Margin="10,10,10,15"/>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">
                <ItemsControl x:Name="lstForecast">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource WeatherCard}" Width="180" Height="220">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Data}" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" Foreground="{StaticResource BrandMuted}"/>
                                    <TextBlock Text="🌡️" FontSize="40" HorizontalAlignment="Center" Margin="0,15"/>
                                    <TextBlock Text="{Binding Egoera}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10" Height="45" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Min}" Foreground="Blue" FontWeight="Bold"/>
                                        <TextBlock Text="° / " Foreground="{StaticResource BrandMuted}"/>
                                        <TextBlock Text="{Binding Max}" Foreground="Red" FontWeight="Bold"/>
                                        <TextBlock Text="°" Foreground="{StaticResource BrandMuted}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Footer / Close -->
        <Grid Grid.Row="3" Margin="0,20,0,0">
            <TextBlock Text="Datuak: AEMET" VerticalAlignment="Center" Foreground="{StaticResource BrandMuted}" FontStyle="Italic"/>
            <Button Content="Itxi" Width="120" HorizontalAlignment="Right"
                    Style="{StaticResource LuxuryPrimaryButton}" Click="Itxi_Klik"/>
        </Grid>
    </Grid>
</Window>
