<Window x:Class="Tpv.ErreserbakPantaila"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Title="Erreserbak"
            WindowState="Maximized"
            WindowStyle="None"
            ResizeMode="CanResize"
            Background="{StaticResource BrandSoft}">
    <Window.Resources>
        <Style x:Key="MahaiaStyle" TargetType="Button">
            <Setter Property="Width" Value="300"/>
            <Setter Property="Height" Value="160"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="{StaticResource BrandSurface}"/>
            <Setter Property="Foreground" Value="{StaticResource BrandBlack}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandChampagne}"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ErreserbaBotoia" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrandGold}"/>
            <Setter Property="Foreground" Value="{StaticResource BrandBlack}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Width="30" Height="30" Fill="{StaticResource BrandBlack}" Margin="0,0,10,0">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/sushi.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrandChampagne}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B88C35"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Background="{StaticResource BrandBlack}" Grid.Row="0" MouseLeftButtonDown="Titulua_EzkerrekoBotoiaKlik">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,3,0,0">
                <Button Grid.Column="0" Background="Transparent" Margin="4" BorderThickness="0" Cursor="Hand" Click="Atzera_Klik" HorizontalAlignment="Left">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle x:Name="Gezia_ezkerrera" Width="35" Height="35" Fill="{StaticResource BrandIvory}" Margin="3">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/gezia.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2C2415"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#2C2415"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Click="Txat_Klik">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle Width="35" Height="35" Fill="{StaticResource BrandGold}" Margin="3">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/txat.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Grid.Column="0"
            Background="Transparent"
            BorderThickness="0"
            Cursor="Hand"
            Click="Profila_Klik"
            Margin="4"
            HorizontalAlignment="Left">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle Width="35"
                            Height="35"
                            Fill="{StaticResource BrandIvory}">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/usuario.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2C2415"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#2C2415"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.ToolTip>
                        <Border Background="{StaticResource BrandSurface}" CornerRadius="5" Padding="3">
                            <TextBlock Text="Saioa Itxi"
                               Foreground="{StaticResource BrandBlack}"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                        </Border>
                    </Button.ToolTip>
                </Button>
                <Button Content="_" Width="45" Height="45" Margin="4" Click="Minimizatu_Klik" Background="Transparent" Foreground="{StaticResource BrandIvory}" FontSize="22" FontWeight="Bold"/>
                <Button Content="X" Width="45" Height="45" Margin="4" Click="Itxi_Klik" Background="Transparent" Foreground="{StaticResource BrandIvory}" FontSize="22" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="MahaiaGrid" Background="Transparent">
                    <Button x:Name="Mahaia1" Content="Mahaia 1" Width="350" Height="125" Canvas.Left="0" Canvas.Top="0" Click="Mahaia_Klik" Style="{StaticResource MahaiaStyle}"/>
                    <Button x:Name="Mahaia2" Content="Mahaia 2" Width="250" Height="200" Canvas.Left="0" Canvas.Top="200" Click="Mahaia_Klik" Style="{StaticResource MahaiaStyle}"/>
                    <Button x:Name="Mahaia3" Content="Mahaia 3" Width="300" Height="200" Canvas.Left="0" Canvas.Top="500" Click="Mahaia_Klik" Style="{StaticResource MahaiaStyle}"/>
                    <Button x:Name="Mahaia4" Content="Mahaia 4" Width="200" Height="350" Canvas.Left="550" Canvas.Top="0" Click="Mahaia_Klik" Style="{StaticResource MahaiaStyle}"/>
                    <Button x:Name="Mahaia5" Content="Mahaia 5" Width="200" Height="350" Canvas.Left="550" Canvas.Top="400" Click="Mahaia_Klik" Style="{StaticResource MahaiaStyle}"/>
                </Canvas>
            </ScrollViewer>
            

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="10">
                    <Border Background="{StaticResource BrandSurface}"
                            BorderBrush="{StaticResource BrandChampagne}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Margin="0,0,150,200"
                            HorizontalAlignment="Center">
                        <Calendar x:Name="egutegia"
                                  DisplayMode="Month"
                                  SelectionMode="SingleDate"
                                  SelectedDatesChanged="Egutegia_aldatu"
                                  Margin="10">
                            <Calendar.LayoutTransform>
                                <ScaleTransform ScaleX="2.5" ScaleY="2.5"/>
                            </Calendar.LayoutTransform>
                        </Calendar>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0">
                        <Button Style="{StaticResource ErreserbaBotoia}"
                                Width="180"
                                Height="70"
                                Click="Bazkaria_Klik">
                            <TextBlock Text="Bazkaria"/>
                        </Button>
                        <Button Style="{StaticResource ErreserbaBotoia}"
                                Width="180"
                                Height="70"
                                Click="Afaria_Klik">
                            <TextBlock Text="Afaria"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
            
        </Grid>
        
    </Grid>
</Window>
