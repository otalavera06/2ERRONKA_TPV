<Window x:Class="Tpv.ErreserbaEguneratuPantaila"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Erreserba eguneratu"
        MinWidth="450" MinHeight="350"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="TopBarButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Rectangle Width="18"
                                       Height="18"
                                       Fill="#EEEEEE">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E9C4C7"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E9C4C7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ErreserbaBotoia" TargetType="Button">
            <Setter Property="Background" Value="#E9C4C7"/>
            <Setter Property="Foreground" Value="#373F47"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Width="20" Height="20" Fill="White" Margin="0,0,10,0">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="/Irudiak/sushi.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B92732"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B92732"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Viewbox Stretch="Uniform">
        <Grid Width="350" Height="250">
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Background="#373F47" Grid.Row="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Style="{StaticResource TopBarButtonStyle}"
                            Tag="/Irudiak/aldatu.png"
                            ToolTip="Aldatu"
                            Click="Aldatu_Klik"
                            Margin="5"/>
                    <Button Style="{StaticResource TopBarButtonStyle}"
                            Tag="/Irudiak/ezabatu.png"
                            ToolTip="Ezabatu"
                            Click="Ezabatu_Klik"
                            Margin="5"/>
                    <Button Content="X"
                            Width="35" Height="35"
                            Margin="5"
                            Background="Transparent"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            Click="Itxi_Klik">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E9C4C7"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#E9C4C7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
            
            <StackPanel Grid.Row="1" Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Egunez aldatu: " FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                <DatePicker x:Name="dataPicker" Margin="0,0,0,20" Width="200"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                    <Button x:Name="Bazkaria_Btn"
                            Style="{StaticResource ErreserbaBotoia}"
                            Width="120"
                            Height="40"
                            Margin="10"
                            Click="Bazkaria_Klik">
                        <TextBlock Text="Bazkaria"/>
                    </Button>
                    <Button x:Name="Afaria_Btn"
                            Style="{StaticResource ErreserbaBotoia}"
                            Width="120"
                            Height="40"
                            Margin="10"
                            Click="Afaria_Klik">
                        <TextBlock Text="Afaria"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Viewbox>
</Window>
