<Window x:Class="Tpv.SaioaItxiDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Saioa itxi"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        SizeToContent="WidthAndHeight"
        WindowStyle="SingleBorderWindow"
        Width="200" Height="200">
    <StackPanel Margin="20">
        <TextBlock Text="Seguru saioa itxi nahi duzula?"
                   FontSize="22"
                   Margin="0,0,0,15"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Width="100" Height="50" Margin="5" IsDefault="True" Click="Bai_Klik" Background="#4CAF50" Foreground="White">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Width="20" Height="20" Fill="White" Margin="0,0,5,0">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/gezia.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Bai" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Width="100" Height="50" Margin="5" IsCancel="True" Click="Ez_Klik" Background="#F44336" Foreground="White">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Width="20" Height="20" Fill="White" Margin="0,0,5,0">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/ezabatu.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Ez" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>