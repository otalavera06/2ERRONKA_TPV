<Window x:Class="Tpv.EskaerakPantaila"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Title="Eskaerak"
             WindowState="Maximized"
             WindowStyle="None"
             ResizeMode="CanResize"
             Background="{StaticResource BrandSoft}">
    <Window.Resources>
        <Style TargetType="{x:Type Button}" x:Key="EskaerakBotoia" BasedOn="{StaticResource LuxuryCardButton}">
            <Setter Property="Foreground" Value="{StaticResource BrandIvory}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="{StaticResource BrandBlack}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="15"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Background="{StaticResource BrandBlack}" Grid.Row="0" MouseLeftButtonDown="Titulua_EzkerrekoBotoiaKlik">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,3,0,0">
                <Button Grid.Column="0" Background="Transparent" Margin="4" BorderThickness="0" Cursor="Hand" Click="Atzera_Klik" HorizontalAlignment="Left">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle x:Name="Gezia_ezkerrera" Width="35" Height="35" Fill="{StaticResource BrandIvory}" Margin="3">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/gezia.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2C2415"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#2C2415"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Click="Txat_Klik">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle Width="35" Height="35" Fill="{StaticResource BrandGold}" Margin="3">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/txat.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Grid.Column="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Profila_Klik"
                    Margin="4"
                    HorizontalAlignment="Left">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle Width="35"
                           Height="35"
                           Fill="{StaticResource BrandIvory}">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/usuario.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2C2415"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#2C2415"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.ToolTip>
                        <Border Background="{StaticResource BrandSurface}" CornerRadius="5" Padding="3">
                            <TextBlock Text="Saioa Itxi"
                               Foreground="{StaticResource BrandBlack}"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                        </Border>
                    </Button.ToolTip>
                </Button>
                <Button Content="_" Width="45" Height="45" Margin="4" Click="Minimizatu_Klik" Background="Transparent" Foreground="{StaticResource BrandIvory}" FontSize="22" FontWeight="Bold"/>
                <Button Content="X" Width="45" Height="45" Margin="4" Click="Itxi_Klik" Background="Transparent" Foreground="{StaticResource BrandIvory}" FontSize="22" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.8*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Header="Azken eskaerak" Grid.Row="0" Margin="10" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrandBlack}">
                    <TreeView x:Name="lsAzkenEskaerak"
                             Height="200"
                             Background="{StaticResource BrandSurface}"
                             BorderBrush="{StaticResource BrandChampagne}"
                             BorderThickness="1"
                             FontSize="16"
                             MouseDoubleClick="LsAzkenEskaerak_DoubleKlik">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Eskaerak}">
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <TextBlock Text="{Binding ZerbitzuaHeader}"
                                               Foreground="#333"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="8,2,2,2">
                                            <TextBlock Text="{Binding Izena}"
                                                       Foreground="#555"
                                                       Width="100"/>
                                            <TextBlock Text="{Binding Prezioa, StringFormat='{}{0}€'}"
                                                         Foreground="#777"
                                                         Width="50"/>
                                            <Button Width="20" Height="20" Margin="5,0,0,0" Click="BtnGehituAzkenetik_Klik" ToolTip="Gehitu">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Rectangle Width="20" Height="20" Fill="{StaticResource BrandGold}">
                                                            <Rectangle.OpacityMask>
                                                                <ImageBrush ImageSource="Irudiak/gezia.png"/>
                                                            </Rectangle.OpacityMask>
                                                        </Rectangle>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </GroupBox>

                <StackPanel Grid.Row="1" Margin="10">
                    <TextBlock Text="Momentuko eskaera"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrandBlack}"
                               Margin="0,0,0,10"/>
                    <Border x:Name="editatzenBanner"
                            Visibility="Collapsed"
                            Background="{StaticResource BrandChampagne}"
                            CornerRadius="6"
                            Padding="10,6"
                            Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Editatzen: "
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandBlack}"/>
                            <TextBlock x:Name="txtEditatzenInfo"
                                       Foreground="{StaticResource BrandBlack}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <ListBox x:Name="lsEskaerak"
                             Height="250"
                             FontSize="16"
                             Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="{Binding Izena}"
                                               Foreground="#555"
                                               Width="120"/>
                                    <TextBlock Text="{Binding Prezioa, StringFormat='{}{0}€'}"
                                                 Foreground="#777"
                                                 Width="50"/>
                                    <Button Width="20" Height="20" Margin="5,0,0,0" Click="BtnKenduProduktua_Klik" ToolTip="Kendu">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Rectangle Width="20" Height="20" Fill="{StaticResource BrandGold}">
                                                    <Rectangle.OpacityMask>
                                                        <ImageBrush ImageSource="Irudiak/ezabatu.png"/>
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="txtUnekoTotala"
                               Text="Guztira: 0,00€"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandBlack}"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtOdooDeskontua"
                               Text="Odoo: ez dago deskonturik aplikatuta"
                               FontSize="14"
                               Foreground="{StaticResource BrandMuted}"
                               Margin="0,0,0,10"
                               TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Deskontu kodea:"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{StaticResource BrandBlack}"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="txtDeskontuKodea"
                                 Width="150"
                                 Height="30"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnEskaeraJaso"
                                Style="{StaticResource EskaerakBotoia}"
                                Width="140"
                                Height="100"
                                Click="BtnEskaeraJaso_Klik">
                            <StackPanel>
                                <Rectangle Width="40" Height="40" Fill="{StaticResource BrandGold}" Margin="0,0,0,5" HorizontalAlignment="Center">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/eskaeraJaso.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock x:Name="txtEskaeraJasoBotoia"
                                           Text="Eskaera jaso"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource EskaerakBotoia}"
                                Width="160"
                                Height="100"
                                Click="BtnOdooDeskontua_Klik">
                            <StackPanel>
                                <Rectangle Width="40" Height="40" Fill="{StaticResource BrandGold}" Margin="0,0,0,5" HorizontalAlignment="Center">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/eskaera.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Odoo deskontua" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource EskaerakBotoia}"
                                Width="140"
                                Height="100"
                                Click="BtnOrdaindu_Klik">
                            <StackPanel>
                                <Rectangle Width="40" Height="40" Fill="{StaticResource BrandGold}" Margin="0,0,0,5" HorizontalAlignment="Center">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/ordaindu.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Ordaindu" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <TabControl Grid.Column="1" Margin="10" Background="Transparent" BorderThickness="0">
                <TabItem Header="Produktuak" FontSize="18" FontWeight="SemiBold">
                    <ScrollViewer Margin="0,10,0,0">
                        <UniformGrid x:Name="gridProduktuak" Columns="4"/>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Platerak" FontSize="18" FontWeight="SemiBold">
                    <ScrollViewer Margin="0,10,0,0">
                        <UniformGrid x:Name="gridPlaterak" Columns="4"/>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
