<Window x:Class="Tpv.EskaerakPantaila"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Title="Eskaerak"
             WindowState="Maximized"
             WindowStyle="None"
             ResizeMode="CanResize"
             Background="#EEEEEE">
    <Window.Resources>
        <Style TargetType="{x:Type Button}" x:Key="EskaerakBotoia">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="#E9C4C7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="15"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B92732"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B92732"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Background="#373F47" Grid.Row="0" MouseLeftButtonDown="Titulua_EzkerrekoBotoiaKlik">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,3,0,0">
                <Button Grid.Column="0" Background="Transparent" Margin="4" BorderThickness="0" Cursor="Hand" Click="Atzera_Klik" HorizontalAlignment="Left">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle x:Name="Gezia_ezkerrera" Width="35" Height="35" Fill="#EEEEEE" Margin="3">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/gezia.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E9C4C7"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#E9C4C7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Click="Txat_Klik">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle Width="35" Height="35" Fill="White" Margin="3">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/txat.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Grid.Column="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Profila_Klik"
                    Margin="4"
                    HorizontalAlignment="Left">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle Width="35"
                           Height="35"
                           Fill="#EEEEEE">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/usuario.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E9C4C7"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#E9C4C7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.ToolTip>
                        <Border Background="#EEEEEE" CornerRadius="5" Padding="3">
                            <TextBlock Text="Saioa Itxi"
                               Foreground="#373F47"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                        </Border>
                    </Button.ToolTip>
                </Button>
                <Button Content="_" Width="45" Height="45" Margin="4" Click="Minimizatu_Klik" Background="Transparent" Foreground="White" FontSize="22" FontWeight="Bold"/>
                <Button Content="X" Width="45" Height="45" Margin="4" Click="Itxi_Klik" Background="Transparent" Foreground="White" FontSize="22" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.8*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Header="Azken eskaerak" Grid.Row="0" Margin="10" FontSize="20" FontWeight="Bold" Foreground="#2c2c2c">
                    <TreeView x:Name="lsAzkenEskaerak"
                             Height="200"
                             Background="White"
                             BorderBrush="#DDD"
                             BorderThickness="1"
                             FontSize="16"
                             MouseDoubleClick="LsAzkenEskaerak_DoubleKlik">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Eskaerak}">
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <TextBlock Text="{Binding ZerbitzuaHeader}"
                                               Foreground="#333"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="8,2,2,2">
                                            <TextBlock Text="{Binding Izena}"
                                                       Foreground="#555"
                                                       Width="120"/>
                                            <TextBlock Text="{Binding Prezioa, StringFormat='{}{0}€'}"
                                                         Foreground="#777"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>

                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </GroupBox>

                <StackPanel Grid.Row="1" Margin="10">
                    <TextBlock Text="Momentuko eskaera"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#373F47"
                               Margin="0,0,0,10"/>
                    <ListBox x:Name="lsEskaerak"
                             Height="250"
                             FontSize="16"
                             Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtUnekoTotala"
                               Text="Guztira: 0,00€"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#373F47"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtOdooDeskontua"
                               Text="Odoo: ez dago deskonturik aplikatuta"
                               FontSize="14"
                               Foreground="#666666"
                               Margin="0,0,0,10"
                               TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource EskaerakBotoia}"
                                Width="140"
                                Height="100"
                                Click="BtnEskaeraJaso_Klik">
                            <StackPanel>
                                <Rectangle Width="40" Height="40" Fill="White" Margin="0,0,0,5" HorizontalAlignment="Center">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/eskaeraJaso.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Eskaera jaso" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource EskaerakBotoia}"
                                Width="140"
                                Height="100"
                                Click="BtnKendu_Klik">
                            <StackPanel>
                                <Rectangle Width="40" Height="40" Fill="White" Margin="0,0,0,5" HorizontalAlignment="Center">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/ezabatu.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Kendu" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource EskaerakBotoia}"
                                Width="160"
                                Height="100"
                                Click="BtnOdooDeskontua_Klik">
                            <StackPanel>
                                <Rectangle Width="40" Height="40" Fill="White" Margin="0,0,0,5" HorizontalAlignment="Center">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/eskaera.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Odoo deskontua" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource EskaerakBotoia}"
                                Width="140"
                                Height="100"
                                Click="BtnOrdaindu_Klik">
                            <StackPanel>
                                <Rectangle Width="40" Height="40" Fill="White" Margin="0,0,0,5" HorizontalAlignment="Center">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/ordaindu.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Ordaindu" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <ScrollViewer Grid.Column="1" Margin="10">
                <UniformGrid x:Name="gridEdariak" Columns="4"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
