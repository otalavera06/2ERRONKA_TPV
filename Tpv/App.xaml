<Application  x:Class="Tpv.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BrandBlack" Color="#0B0B0B"/>
        <SolidColorBrush x:Key="BrandGold" Color="#C9A24A"/>
        <SolidColorBrush x:Key="BrandIvory" Color="#F5F0E6"/>
        <SolidColorBrush x:Key="BrandChampagne" Color="#E7D2A2"/>
        <SolidColorBrush x:Key="BrandSoft" Color="#F4EFE6"/>
        <SolidColorBrush x:Key="BrandSurface" Color="#FFFDFC"/>
        <SolidColorBrush x:Key="BrandMuted" Color="#6E675A"/>

        <Style x:Key="LuxuryPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrandGold}"/>
            <Setter Property="Foreground" Value="{StaticResource BrandBlack}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrandChampagne}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B88C35"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LuxuryCardButton" TargetType="Button" BasedOn="{StaticResource LuxuryPrimaryButton}">
            <Setter Property="Background" Value="{StaticResource BrandBlack}"/>
            <Setter Property="Foreground" Value="{StaticResource BrandIvory}"/>
            <Setter Property="FontSize" Value="20"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1A1A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2C2415"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
 
</Application>
