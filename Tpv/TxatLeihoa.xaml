<Window x:Class="Tpv.TxatLeihoa"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Txata" Height="500" Width="800"
        Background="{StaticResource BrandSoft}">

    <Grid Background="{StaticResource BrandSoft}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource BrandBlack}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="Kontaktuak" Foreground="{StaticResource BrandIvory}" 
                       Margin="15,15,0,10" FontWeight="Bold" FontSize="12"/>

            <ListBox x:Name="lstContacts" Grid.Row="1" 
                     Background="Transparent" BorderThickness="0"
                     SelectionChanged="LstContacts_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Border" CornerRadius="4" Margin="5,2" Padding="8" Background="{TemplateBinding Background}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#2C2415"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BrandGold}"/>
                                            <Setter TargetName="Border" Property="TextElement.Foreground" Value="{StaticResource BrandBlack}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="{StaticResource BrandGold}" Margin="0,0,10,0">
                                <TextBlock Text="{Binding Initials}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                            </Border>
                            
                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Foreground="{StaticResource BrandIvory}" FontWeight="SemiBold"/>
                            
                            <Border Grid.Column="2" Background="#ED4245" CornerRadius="9" MinWidth="18" Height="18" 
                                    Visibility="{Binding UnreadVisibility}">
                                <TextBlock Text="{Binding UnreadCount}" Foreground="White" FontSize="11" FontWeight="Bold" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid Grid.Column="1" Background="{StaticResource BrandSurface}">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="{StaticResource BrandBlack}" BorderThickness="0,0,0,1" Padding="15,0" Background="{StaticResource BrandBlack}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="#" Foreground="{StaticResource BrandGold}" FontSize="20" Margin="0,0,5,0"/>
                    <TextBlock x:Name="txtChatTitle" Text="Aukeratu kontaktu bat" Foreground="{StaticResource BrandIvory}" FontWeight="Bold" FontSize="16"/>
                </StackPanel>
            </Border>

            <ListBox x:Name="lstMezuak" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,0,0,10"
                     MouseDoubleClick="LstMezuak_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Margin="10,0,0,0" VerticalAlignment="Top">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding AvatarColor}"/>
                                </Border.Background>
                                <TextBlock Text="{Binding Initials}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="{Binding SenderName}" Foreground="{Binding NameColor}" FontWeight="Bold" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding TimeStamp}" Foreground="{StaticResource BrandMuted}" FontSize="11" VerticalAlignment="Bottom"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Testua}" Foreground="{StaticResource BrandBlack}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2" Margin="15,0,15,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="{StaticResource BrandSurface}" CornerRadius="8">
                    <TextBox x:Name="txtMezua"
                             Background="Transparent"
                             Foreground="{StaticResource BrandBlack}"
                             BorderThickness="0"
                             Padding="10"
                             VerticalContentAlignment="Center"
                             FontSize="14"
                             KeyDown="TxtMezua_KeyDown"/>
                </Border>

                <Button Grid.Column="1" Margin="10,0,0,0"
                        Width="40" Height="40"
                        Background="{StaticResource BrandSurface}"
                        Foreground="{StaticResource BrandBlack}"
                        BorderThickness="0"
                        Click="BtnEmoji_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                <TextBlock Text="😊" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Grid.Column="2" Margin="10,0,0,0"
                        Width="40" Height="40"
                        Background="{StaticResource BrandSurface}"
                        Foreground="{StaticResource BrandBlack}"
                        BorderThickness="0"
                        Click="BtnArxibo_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                <TextBlock Text="📎" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="3" Margin="10,0,0,0"
                        Width="40" Height="40"
                        Background="{StaticResource BrandGold}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="BtnBidali_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                <TextBlock Text="➤" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
