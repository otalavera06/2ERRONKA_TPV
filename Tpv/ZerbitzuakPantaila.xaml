<Window x:Class="Tpv.ZerbitzuakPantaila"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zerbitzuak"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource BrandSoft}">
    <Window.Resources>
        <Style TargetType="{x:Type Button}" x:Key="MahaiaBotoia" BasedOn="{StaticResource LuxuryCardButton}">
            <Setter Property="Foreground" Value="{StaticResource BrandIvory}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Background" Value="{StaticResource BrandBlack}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="15" Background="{TemplateBinding Background}" BorderBrush="{StaticResource BrandGold}" BorderThickness="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Background="{StaticResource BrandBlack}" Grid.Row="0" MouseLeftButtonDown="Titulua_EzkerrekoBotoiaKlik">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,3,0,0">
                <Button Background="Transparent" Margin="4" BorderThickness="0" Cursor="Hand" Click="Atzera_Klik" HorizontalAlignment="Left">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Rectangle Width="35" Height="35" Fill="{StaticResource BrandIvory}" Margin="3">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/gezia.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Content="_" Width="45" Height="45" Margin="4" Click="Minimizatu_Klik" Background="Transparent" Foreground="{StaticResource BrandIvory}" FontSize="22" FontWeight="Bold"/>
                <Button Content="X" Width="45" Height="45" Margin="4" Click="Itxi_Klik" Background="Transparent" Foreground="{StaticResource BrandIvory}" FontSize="22" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="Aukeratu Mahaia / Zerbitzua" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BrandBlack}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <UniformGrid x:Name="gridMahaiak" Grid.Row="1" Columns="3" Rows="2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <!-- Buttons will be generated in C# -->
            </UniformGrid>
        </Grid>
    </Grid>
</Window>
