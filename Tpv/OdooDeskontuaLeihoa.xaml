<Window x:Class="Tpv.OdooDeskontuaLeihoa"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Deskontuak"
        Width="420"
        Height="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrandSurface}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Odoo deskontua"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{StaticResource BrandBlack}"/>
        <TextBlock Grid.Row="1"
                   Text="Idatzi fakturan aplikatu nahi den deskontu kodea."
                   Margin="0,8,0,16"
                   Foreground="{StaticResource BrandMuted}"
                   TextWrapping="Wrap"/>
        <TextBox x:Name="txtKodea"
                 Grid.Row="2"
                 Height="38"
                 FontSize="16"
                 Padding="10,6"
                 VerticalContentAlignment="Center"
                 BorderBrush="{StaticResource BrandChampagne}"
                 Background="{StaticResource BrandSoft}"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Utzi"
                    Width="90"
                    Margin="0,0,10,0"
                    Click="Utzi_Klik"/>
            <Button Content="Aplikatu"
                    Width="110"
                    IsDefault="True"
                    Click="Aplikatu_Klik"/>
        </StackPanel>
    </Grid>
</Window>
