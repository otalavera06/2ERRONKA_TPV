<Window x:Class="Tpv.LoginPantaila"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Title="Musinelli TPV"
             ResizeMode="CanResize"
             WindowStartupLocation="CenterScreen"
             Height="560" Width="980"
             WindowStyle="None"
             Background="{StaticResource BrandSoft}">
    <Window.Resources>
        <Style x:Key="LoginButtonStyle" TargetType="Button" BasedOn="{StaticResource LuxuryPrimaryButton}">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Width="28" Height="28" Fill="{StaticResource BrandBlack}" Margin="0,0,10,0">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/saioaHasi.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.8*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BrandBlack}">
                <Grid Margin="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="Irudiak/logo2erronkabien.png"
                               Width="200"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                        <TextBlock Text="TPV"
                                   Foreground="{StaticResource BrandGold}"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource BrandSurface}" Padding="55">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">
                    <TextBlock Text="Musinelli"
                               Foreground="{StaticResource BrandBlack}"
                               FontSize="34"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Saioa hasi"
                               Foreground="{StaticResource BrandMuted}"
                               FontSize="18"
                               Margin="0,8,0,30"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Erabiltzailea:"
                       Foreground="{StaticResource BrandBlack}"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>
                    <TextBox x:Name="txtErabiltzailea"
                       Background="{StaticResource BrandSoft}"
                       BorderBrush="{StaticResource BrandChampagne}"
                       BorderThickness="2"
                       Padding="12"
                       FontSize="20"
                       Margin="0,0,0,18"/>
                    <TextBlock Text="Pasahitza:"
                       Foreground="{StaticResource BrandBlack}"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>
                    <PasswordBox x:Name="txtPasahitza"
                       Background="{StaticResource BrandSoft}"
                       BorderBrush="{StaticResource BrandChampagne}"
                       BorderThickness="2"
                       Padding="12"
                       FontSize="20"
                       Margin="0,0,0,26"/>
                    <Button x:Name="btnLogin"
                        Style="{StaticResource LoginButtonStyle}"
                        IsDefault="True"
                        Click="BtnLogin_Klik"
                        Content="Saioa hasi">
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Background="Transparent"
              Height="40"
              VerticalAlignment="Top"
              MouseLeftButtonDown="Titulua_EzkerrekoBotoiaKlik">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Content="_" Width="40" Height="30" Margin="3" Click="Minimizatu_Klik" Background="Transparent" Foreground="{StaticResource BrandIvory}" FontSize="22" FontWeight="Bold"/>
                <Button Content="X" Width="40" Height="30" Margin="3" Click="Itxi_Klik" Background="Transparent" Foreground="{StaticResource BrandIvory}" FontSize="22" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
