<Window x:Class="Tpv.LoginPantaila"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Title="LoginPantaila"
             ResizeMode="CanResize"
             WindowStartupLocation="CenterScreen"
             Height="450" Width="800"
             WindowStyle="None"
             Background="#EEEEEE">
    <Window.Resources>
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#373F47"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Width="30" Height="30" Fill="White" Margin="0,0,10,0">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="Irudiak/saioaHasi.png"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2C333A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2C333A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FCFEFC">
                <Image Source="Irudiak/sushineli.png"
                   Stretch="Uniform"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>
            </Border>

            <Border Grid.Column="1" Background="#B92732" Padding="40">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                    <TextBlock Text="Erabiltzailea:"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,5"/>
                    <TextBox x:Name="txtErabiltzailea"
                       Background="#FCFEFC"
                       FontSize="24"
                       Margin="0,0,0,15"/>
                    <TextBlock Text="Pasahitza:"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPasahitza"
                       Background="#FCFEFC"
                       FontSize="24"
                       Margin="0,0,0,20"/>
                    <Button x:Name="btnLogin"
                        Style="{StaticResource LoginButtonStyle}"
                        IsDefault="True"
                        Click="BtnLogin_Klik"
                        Content="Saioa hasi">
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Background="Transparent"
              Height="40"
              VerticalAlignment="Top"
              MouseLeftButtonDown="Titulua_EzkerrekoBotoiaKlik">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Content="_" Width="40" Height="30" Margin="3" Click="Minimizatu_Klik" Background="Transparent" Foreground="White" FontSize="22" FontWeight="Bold"/>
                <Button Content="X" Width="40" Height="30" Margin="3" Click="Itxi_Klik" Background="Transparent" Foreground="White" FontSize="22" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
